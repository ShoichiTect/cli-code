{
    "name": "mini-ts",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc",
        "demo:v2": "tsx demo/v2/main.ts",
        "demo:v2:test": "node --import tsx --test demo/v2/test.ts",
        "lint": "biome check demo/v2",
        "lint:fix": "biome check --write demo/v2",
        "postbuild": "node scripts/add-shebang.mjs",
        "start": "node dist/index.js",
        "format": "biome format --write demo/v2",
        "format:check": "biome format demo/v2"
    },
    "bin": {
        "mini-ts": "dist/index.js"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "chalk": "^5.3.0",
        "dotenv": "^16.4.5",
        "marked": "^12.0.2",
        "marked-terminal": "^7.2.1",
        "openai": "^6.16.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^20.11.0",
        "prettier": "^3.8.0",
        "tsx": "^4.19.0",
        "typescript": "^5.3.3"
    }
}
